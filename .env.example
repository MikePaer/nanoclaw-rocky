# NanoClaw configuration. Copy to `.env` and fill in real values.
# Values are read at process start — restart NanoClaw after editing.
# `.env` is git-ignored; `.env.example` is the canonical template.

# ─── Core ─────────────────────────────────────────────────────────────────────

# IANA timezone for scheduled tasks, message timestamps, skill outputs.
TZ=America/Los_Angeles

# Agent identity. Triggers default to "@<ASSISTANT_NAME>".
# ASSISTANT_NAME=Andy
# ASSISTANT_HAS_OWN_NUMBER=false

# ─── OneCLI gateway (Anthropic credential proxy) ──────────────────────────────
# OneCLI injects API keys / OAuth tokens into containers at request time so the
# raw secrets never reach the agent. Run `onecli --help` for setup.
ONECLI_URL=http://127.0.0.1:10254
# ONECLI_API_KEY=<set if onecli requires auth>

# ─── Runtime tuning (all optional — defaults shown) ───────────────────────────
# LOG_LEVEL=info                      # trace | debug | info | warn | error
# IDLE_TIMEOUT=1800000                # ms before an idle container is killed (30m)
# MAX_CONCURRENT_CONTAINERS=5
# MAX_MESSAGES_PER_PROMPT=10
# CONTAINER_TIMEOUT=1800000           # ms cap per container run (30m)
# CONTAINER_MAX_OUTPUT_SIZE=10485760  # bytes (10MB)
# CONTAINER_IMAGE=nanoclaw-agent:latest

# Hosts the container should reach WITHOUT going through the OneCLI proxy.
# Loopback + Docker gateway are always bypassed; add LAN services here.
# Literal hostnames/IPs only — no CIDR or wildcards (Node fetch limitation).
NO_PROXY=localhost,127.0.0.1,host.docker.internal

# ─── Channels ─────────────────────────────────────────────────────────────────
# Channel-specific tokens (SLACK_*, TELEGRAM_BOT_TOKEN, DISCORD_BOT_TOKEN, etc.)
# are appended to this file by their installer skills (`/add-slack`, etc.).

# Signal (channel: signal-cli on the host)
SIGNAL_PHONE_NUMBER=+15555550100
# SIGNAL_CLI_PATH=signal-cli          # falls back to PATH

# Webhook (HTTP POST channel for LAN services like Home Assistant)
WEBHOOK_PORT=8765
WEBHOOK_BIND_HOST=127.0.0.1
WEBHOOK_AUTH_TOKEN=replace-with-random-bearer-token
# WEBHOOK_ROUTES=alarm:home,unifi:home  # optional path → group folder map

# ─── Skills (only set the ones whose skills you've installed) ─────────────────

# /flight-status — AviationStack (https://aviationstack.com)
AVIATION_STACK_API_KEY=

# /fetch-media — Jellyseerr / Overseerr
JELLYFIN_URL=http://jellyfin.lan:8096
JELLYFIN_API_KEY=
SEERR_URL=http://seerr.lan:5055
SEERR_API_KEY=

# /outlook-calendar — Microsoft Graph (Entra app, public client + Calendars.ReadWrite)
OUTLOOK_CLIENT_ID=

# Forecaster (private internal API — placeholder)
FORECASTER_API_URL=
FORECASTER_API_KEY=

# Payroll (private internal API — placeholder)
PAYROLL_API_URL=
PAYROLL_TOKEN=

# /garbage-pickup — municipal iCal feed (Recollect for Seattle SPU)
GARBAGE_PICKUP_ICS_URL=https://recollect-us.global.ssl.fastly.net/api/places/<place-id>/services/<service-id>/events.en-US.ics
# GARBAGE_PICKUP_TIMEZONE=America/Los_Angeles  # optional override; defaults to TZ
